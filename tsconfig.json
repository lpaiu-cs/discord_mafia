{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "mafia/.cache/root-build.tsbuildinfo",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["mafia/src/**/*.ts", "liar/src/**/*.ts"],
  "exclude": ["mafia/src/web/client/**/*.ts"]
}
