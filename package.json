{
  "name": "discord_mafia",
  "version": "2.1.0",
  "description": "Discord lobby + web dashboard bot for Mafia42 season 4 style games",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:preview": "powershell -NoProfile -Command \"$env:DISCORD_BOT_TOKEN='preview-token'; $env:DISCORD_APPLICATION_ID='preview-app'; $env:PUBLIC_BASE_URL='http://localhost:3010'; $env:WEB_SESSION_SECRET='preview-web-session-secret'; $env:JOIN_TICKET_SECRET='preview-join-ticket-secret'; tsx src/dev/web-preview.ts\"",
    "dev:practice": "powershell -NoProfile -Command \"$env:PRACTICE_SCENARIO='practice1'; $env:DISCORD_BOT_TOKEN='practice-token'; $env:DISCORD_APPLICATION_ID='practice-app'; $env:PUBLIC_BASE_URL='http://localhost:3014'; $env:WEB_SESSION_SECRET='practice-web-session-secret'; $env:JOIN_TICKET_SECRET='practice-join-ticket-secret'; tsx src/dev/web-practice.ts\"",
    "dev:practice1": "powershell -NoProfile -Command \"$env:PRACTICE_SCENARIO='practice1'; $env:DISCORD_BOT_TOKEN='practice-token'; $env:DISCORD_APPLICATION_ID='practice-app'; $env:PUBLIC_BASE_URL='http://localhost:3014'; $env:WEB_SESSION_SECRET='practice-web-session-secret'; $env:JOIN_TICKET_SECRET='practice-join-ticket-secret'; tsx src/dev/web-practice.ts\"",
    "dev:practice2": "powershell -NoProfile -Command \"$env:PRACTICE_SCENARIO='practice2'; $env:DISCORD_BOT_TOKEN='practice-token'; $env:DISCORD_APPLICATION_ID='practice-app'; $env:PUBLIC_BASE_URL='http://localhost:3014'; $env:WEB_SESSION_SECRET='practice-web-session-secret'; $env:JOIN_TICKET_SECRET='practice-join-ticket-secret'; tsx src/dev/web-practice.ts\"",
    "dev:practice3": "powershell -NoProfile -Command \"$env:PRACTICE_SCENARIO='practice3'; $env:DISCORD_BOT_TOKEN='practice-token'; $env:DISCORD_APPLICATION_ID='practice-app'; $env:PUBLIC_BASE_URL='http://localhost:3014'; $env:WEB_SESSION_SECRET='practice-web-session-secret'; $env:JOIN_TICKET_SECRET='practice-join-ticket-secret'; tsx src/dev/web-practice.ts\"",
    "dev:practice4": "powershell -NoProfile -Command \"$env:PRACTICE_SCENARIO='practice4'; $env:DISCORD_BOT_TOKEN='practice-token'; $env:DISCORD_APPLICATION_ID='practice-app'; $env:PUBLIC_BASE_URL='http://localhost:3014'; $env:WEB_SESSION_SECRET='practice-web-session-secret'; $env:JOIN_TICKET_SECRET='practice-join-ticket-secret'; tsx src/dev/web-practice.ts\"",
    "dev:practice:all": "powershell -NoProfile -Command \"$env:PRACTICE_SCENARIO='all'; $env:DISCORD_BOT_TOKEN='practice-token'; $env:DISCORD_APPLICATION_ID='practice-app'; $env:PUBLIC_BASE_URL='http://localhost:3014'; $env:WEB_SESSION_SECRET='practice-web-session-secret'; $env:JOIN_TICKET_SECRET='practice-join-ticket-secret'; tsx src/dev/web-practice.ts\"",
    "start": "node dist/index.js",
    "test": "powershell -NoProfile -Command \"$env:DISCORD_BOT_TOKEN='test-token'; $env:DISCORD_APPLICATION_ID='test-app'; $env:PUBLIC_BASE_URL='https://mafia.test'; $env:WEB_SESSION_SECRET='test-web-secret'; $env:JOIN_TICKET_SECRET='test-join-secret'; tsx --test tests/all.test.ts\""
  },
  "keywords": [
    "discord",
    "mafia42",
    "bot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
